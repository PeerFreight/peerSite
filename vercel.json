{
  "git": {
    "deploymentEnabled": {
      "main": true
    }
  },
  "builds": [
    { "src": "site/**", "use": "@vercel/static" },
    { "src": "logos/**", "use": "@vercel/static" },
    { "src": "styles/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/", "dest": "/site/index.html" },
    { "src": "/shippers", "dest": "/site/shippers.html" },
    { "src": "/carriers", "dest": "/site/carriers.html" },
    { "src": "/sitemap.xml", "dest": "/site/sitemap.xml" },
    { "src": "/robots.txt", "dest": "/site/robots.txt" },
    { "src": "/privacy", "dest": "/site/privacy.html" },
    { "src": "/terms", "dest": "/site/terms.html" },
    { "src": "/site/(.*)", "dest": "/site/$1" },
    { "src": "/logos/(.*)", "dest": "/logos/$1" },
    { "src": "/styles/(.*)", "dest": "/styles/$1" }
  ]
}
